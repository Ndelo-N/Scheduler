{
  "name": "student-shift-scheduler-pwa",
  "version": "1.0.0",
  "description": "World-class student shift scheduling and management system PWA",
  "main": "src/js/app.js",
  "scripts": {
    "start": "node server/index.js",
    "start:server": "node server/index.js",
    "dev": "nodemon server/index.js",
    "dev:server": "nodemon server/index.js",
    "provision": "node provision.js",
    "provision:test-student": "node scripts/provision-test-student.js",
    "db:setup": "node database/setup.js setup",
    "db:test": "node database/setup.js test",
    "db:schema": "node database/setup.js schema",
    "db:seed": "node database/setup.js seed",
    "db:migrate": "node database/setup.js migrate",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss src/styles/*.css -d dist/styles",
    "build:js": "webpack --mode production",
    "test": "jest",
    "test:server": "jest tests/server",
    "harness:hours": "node tests/harness/hours.js",
    "test:smoke": "node tests/payrollParser.smoke.js && node tests/identityMap.smoke.js && node tests/effectiveRoster.smoke.js && node tests/reconcile.smoke.js && node tests/schedulingEngine.smoke.js && node tests/schedulingEngineState.smoke.js && node tests/hoursLedger.smoke.js && node tests/escapeHtml.smoke.js && node tests/trustProxy.smoke.js && node tests/dbSsl.smoke.js && node tests/changePasswordLimit.smoke.js",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "serve": "http-server . -p 8080 -c-1"
  },
  "keywords": [
    "pwa",
    "scheduler",
    "student",
    "shifts",
    "education",
    "management"
  ],
  "author": "University of Pretoria",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^9.0.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "cssnano": "^6.0.1",
    "eslint": "^8.55.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/up-ac-za/student-shift-scheduler-pwa.git"
  },
  "bugs": {
    "url": "https://github.com/up-ac-za/student-shift-scheduler-pwa/issues"
  },
  "homepage": "https://github.com/up-ac-za/student-shift-scheduler-pwa#readme"
}
