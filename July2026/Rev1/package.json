{
  "name": "student-shift-scheduler-pwa",
  "version": "1.0.0",
  "description": "World-class student shift scheduling and management system PWA",
  "main": "src/js/app.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "db:setup": "node database/setup.js setup",
    "db:test": "node database/setup.js test",
    "db:schema": "node database/setup.js schema",
    "db:seed": "node database/setup.js seed",
    "db:migrate": "node database/setup.js migrate",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss src/styles/*.css -d dist/styles",
    "build:js": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "serve": "http-server . -p 8080 -c-1"
  },
  "keywords": [
    "pwa",
    "scheduler",
    "student",
    "shifts",
    "education",
    "management"
  ],
  "author": "Lab Scheduler",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "cssnano": "^6.0.1",
    "eslint": "^8.55.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/up-ac-za/student-shift-scheduler-pwa.git"
  },
  "bugs": {
    "url": "https://github.com/up-ac-za/student-shift-scheduler-pwa/issues"
  },
  "homepage": "https://github.com/up-ac-za/student-shift-scheduler-pwa#readme"
}
