# Rev1 auth server — copy to .env and adjust

PORT=3000
NODE_ENV=development

# Postgres (required for npm start / Rev1 auth server)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shift_scheduler
DB_USER=postgres
DB_PASSWORD=password
# DATABASE_URL=postgres://postgres:password@localhost:5432/shift_scheduler

# PWA static root (default: repo root with path guard; production: ./public)
# PWA_DIR=.

# Reverse-proxy hops in front of the app (F-06). Unset/0 = trust nothing (dev,
# direct-connect). Behind a proxy (UP infra) set to the hop count, e.g. 1, so
# client IPs resolve correctly for rate limiting without X-Forwarded-For spoofing.
# TRUST_PROXY=1

# Plain HTTP localhost dev — required for session cookies without TLS
AUTH_INSECURE_COOKIES=1

# TLS lab (scheduler.local) — see Documentation/Brick7_TLS_Runbook.md
# TLS_KEY=./certs/scheduler.local-key.pem
# TLS_CERT=./certs/scheduler.local.pem

SESSION_TTL_MS=43200000
LOG_LEVEL=info

# Client: force auth gate on/off (null = auto-detect via /api/health)
# Set in src/js/config.js as APP_CONFIG.requireAuth
